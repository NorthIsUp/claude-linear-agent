# ============================================================
# Linear OAuth app credentials + webhook signing secret
# ------------------------------------------------------------
# Create the OAuth app: https://linear.app/settings/api/applications
#   Actor:        App user
#   Scopes:       read, write, app:assignable
#   Redirect URI: <BASE_URL>/oauth/callback
#
# Add a webhook inside that same app:
#   URL:          <BASE_URL>/webhook
#   Events:       Agent session events
# ============================================================
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=

# ============================================================
# Claude Code Routines
# ------------------------------------------------------------
# Create a Routine:    https://claude.ai/code/routines
#   Connect the target repo + the Linear MCP connector.
#   Configure the prompt template (see README for a starter).
# CLAUDE_ROUTINE_ID is the trigger ID from the Routine's page
#   (format: trig_XXXXXXXXXXXX).
# CLAUDE_ROUTINE_TOKEN is an Anthropic API key with Routines
#   access: https://console.anthropic.com/settings/keys
# ============================================================
CLAUDE_ROUTINE_ID=
CLAUDE_ROUTINE_TOKEN=

# ============================================================
# Public URL where this server is reachable
# ------------------------------------------------------------
# Required. Must be an absolute URL. Non-localhost hosts MUST
# use https:// — startup fails fast if missing, not an absolute
# URL, or plain http:// for a public host.
#
# Local dev with a tunnel: use the tunnel's https URL here AND
# register the same URL as the Linear OAuth app's redirect URI
# and webhook URL. If the tunnel URL rotates, update both.
# ============================================================
BASE_URL=

PORT=3001

# ============================================================
# Dev-only flags — DO NOT enable in production
# ------------------------------------------------------------
# DEV_PERSIST_TOKEN=1 caches the OAuth access token in a mode-0600
# .token-dev.json so `tsx watch` restarts don't force a full
# re-install. The file is plaintext and gitignored.
#
# DEBUG_PAYLOAD=1 logs the first 6 KB of every AgentSessionEvent
# payload. Helpful for debugging Linear payload shapes.
# ============================================================
# DEV_PERSIST_TOKEN=1
# DEBUG_PAYLOAD=1
